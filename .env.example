# Copy this file to .env or export the same variables in your shell.
ANTHROPIC_API_KEY=

# Optional provider overrides.
# ANTHROPIC_BASE_URL=
# MODEL_ID=
# MODEL_MAX_OUTPUT_TOKENS=4096
# JUDGE_MODEL_ID=

# Optional runtime locations. Defaults are documented in README.md.
# AGENT_WORKDIR=
# TRACES_DIR=
# ACE_HOME=

# Optional MCP stdio example.
# ACE_ENABLE_MCP=1
# ACE_MCP_CONFIG=examples/mcp/.mcp.json

# Optional OpenTelemetry export.
# OTEL_EXPORT=1
# OTEL_ENDPOINT=http://localhost:6006/v1/traces
